$accent: #3b82f6;

Horizontal {
    height: auto;
    padding: 0;
    margin: 0;
}

ListView {
    align: left top;
    margin: 0;
    margin-bottom: 1;
    margin-right: 2;
    border: round $accent;
    padding: 0;
    overflow: auto;
    overflow-x: hidden;
    width: 30%;
    background: transparent;
}

ListItem {
    padding: 1 2;
    background: transparent;
}

/* Keep a background on the selected/highlighted queue item. */
#lanes > ListItem.-highlight {
    background: $accent;
}

Button:focus {
    text-style: bold;
}

#info-container {
    overflow: auto;
}

#form-container {
    overflow: auto;
}

#settings-container {
    overflow: auto;
}

.setting {
    height: auto;
    margin-bottom: 1;
}

.setting-title {
    text-style: bold;
    margin-left: 1;
}

.setting-input {
    width: 50%;
    margin: 0 0 0 1;
}

.setting-desc {
    color: $text-muted;
    margin-left: 4;
}

.info-label {
    text-style: bold;
}

.info-widget {
    width: 100%;
    margin-bottom: 1;
    padding: 1 4;
}

Tree {
    padding: 1 2;
    height: auto;
    background: transparent;
}

/* Transparency: id selectors beat the widgets' own DEFAULT_CSS surface, and
   the tab containers must be transparent too or the tree shows their surface. */
#lanes, #process-tree {
    background: transparent;
}

/* Process tree: guide lines always visible (consistent color, no hover
   change); no hover/cursor line highlight. */
#process-tree > .tree--guides,
#process-tree > .tree--guides-hover,
#process-tree > .tree--guides-selected {
    color: $accent;
    text-style: none;
}

#process-tree > .tree--cursor,
#process-tree > .tree--highlight,
#process-tree > .tree--highlight-line {
    background: transparent;
    text-style: none;
}

TabbedContent, TabPane, ContentSwitcher {
    background: transparent;
}

#navi-container {
    dock: bottom;
    height: 4;
    padding: 0 3;
}

/* Solid, pleasant shades (truecolor passes through in ansi_color mode since
   the ANSI->truecolor filter is disabled). */
#run {
    width: 30%;
    background: #3fb950;
    color: auto;
}

#exit {
    width: 20%;
    dock: right;
    background: #f85149;
    color: auto;
}

Switch {
    width: auto;
    padding: 0;
    border: none;
}

.switch {
    margin: 0 2;
    width: auto;
    height: auto;
    padding: 1;
}

.switch > Label {
    height: 100%;
    margin-left: 2;
}

TabPane {
    width: 70%;
    padding: 1 2;
}

Input {
    margin-left: 2;
    margin-bottom: 1;
}

.form-switch {
    margin: 1 3;
}

Switch > .switch--slider {
    background: #3f3f3f;
}

Slider {
    width: 50%;
}

.slider-container {
    margin-left: 2;
}

.slider-label {
    margin-top: 1;
    margin-left: 1;
}